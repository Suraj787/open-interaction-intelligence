{
  "id": "claim-confirm-destructive-actions",
  "schema_version": 1,
  "claim": {
    "statement": "Require an explicit confirmation step before destructive or irreversible actions (delete, overwrite, discard). Confirmation should clearly name the object and consequence, and the confirm control should be visually distinct from the safe default.",
    "category": "high-risk-action",
    "type": "recommendation",
