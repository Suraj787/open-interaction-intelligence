    "expertise": ["novice", "intermediate", "expert"],
    "risks": ["irreversible"],
    "devices": ["touch", "mobile", "desktop", "keyboard"],
    "audience_roles": ["end-user", "operator", "admin"]
  },
  "evidence": {
    "tier": 3,
    "sources": ["src-nngroup"],
    "methodology": ["expert-review", "industry-best-practice"],
    "confidence": "medium",
    "limitations": ["Overusing confirmations causes dialog fatigue; reserve for genuinely consequential actions"]
  },
  "recommendation": {
    "do": [
      "Interrupt with a confirmation for destructive/irreversible actions",
