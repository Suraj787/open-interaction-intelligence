{
  "id": "claim-avoid-layout-shift-cls",
  "schema_version": 1,
  "claim": {
    "statement": "Avoid unexpected visual movement: keep Cumulative Layout Shift (CLS) at 0.1 or less at the 75th percentile, the 'good' Core Web Vitals threshold. Reserve space for images, media, ads, and async content so loading does not push content the user is reading or about to tap.",
