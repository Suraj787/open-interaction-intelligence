  "evidence": {
    "tier": 1,
    "sources": ["src-web-dev-cwv"],
    "methodology": ["normative-standard", "field-data-thresholds"],
    "confidence": "high",
    "limitations": ["0.1 is the good boundary; >0.25 is poor. Shifts within 500ms of user input are excluded as expected"]
  },
  "recommendation": {
    "do": [
      "Set explicit width/height or aspect-ratio on images and embeds",
      "Reserve space for banners, ads, and dynamically injected content",
      "Use font-display and size-adjust to limit late font reflow"
    ],
    "avoid": [
      "Inserting content above existing content after load",
      "Images and iframes with no dimensions"
    ]
  },
