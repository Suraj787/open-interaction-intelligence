{
  "id": "claim-virtualize-large-lists",
  "schema_version": 1,
  "claim": {
    "statement": "Virtualise (window) large lists and tables so only visible rows are rendered. For collections beyond roughly a thousand rows this keeps DOM node count, memory, and render/scroll time bounded instead of growing with data size.",
    "category": "performance",
    "type": "recommendation",
    "force": "strong-recommendation"
  },
  "applicability": {
    "product_forms": ["web-app", "pwa", "desktop-app", "mobile-web"],
