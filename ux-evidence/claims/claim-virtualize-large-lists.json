    "expertise": ["intermediate", "expert"],
    "devices": ["desktop", "mobile", "touch"],
    "audience_roles": ["operator", "admin", "end-user"]
  },
  "evidence": {
    "tier": 2,
    "sources": ["src-web-dev-cwv"],
    "methodology": ["platform-guideline", "industry-best-practice"],
    "confidence": "high",
    "limitations": ["Virtualisation complicates in-page find, focus order, and a11y; needs careful ARIA and keyboard handling"]
  },
  "recommendation": {
    "do": [
      "Render only the visible window plus a small overscan buffer",
      "Use a maintained virtualisation library (e.g. windowing components)",
      "Preserve keyboard navigation and screen-reader semantics for off-screen rows"
    ],
    "avoid": [
      "Mounting thousands of DOM rows at once",
      "Breaking Ctrl/Cmd+F and focus management when windowing"
    ]
  },
