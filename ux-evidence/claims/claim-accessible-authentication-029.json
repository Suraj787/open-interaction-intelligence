    "confidence": "high",
    "limitations": [
      "New in WCAG 2.2 (Level AA, SC 3.3.8). Allowing password managers/paste and supporting WebAuthn satisfies it."
    ]
  },
  "recommendation": {
    "do": [
      "Allow paste and password-manager autofill on credential fields.",
      "Support passkeys/WebAuthn or email-link alternatives."
    ],
    "avoid": [
      "Blocking paste in password or OTP fields.",
      "Transcription puzzles or memory tests with no alternative."
    ]
  },
