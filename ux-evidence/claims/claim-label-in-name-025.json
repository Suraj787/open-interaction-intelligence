    "limitations": [
      "Where aria-label overrides visible text, speech-recognition users may be unable to target the control."
    ]
  },
  "recommendation": {
    "do": [
      "Ensure aria-label/aria-labelledby starts with or contains the visible text.",
      "Prefer the visible text as the accessible name."
    ],
