    "confidence": "high",
    "limitations": [
      "New in WCAG 2.1, carried into 2.2 (Level AA, SC 4.1.3). Implemented via ARIA live regions / role=status/alert."
    ]
  },
  "recommendation": {
    "do": [
      "Render success, error, progress and result counts in an aria-live region.",
      "Use role=status for polite and role=alert for assertive updates."
    ],
    "avoid": [
      "Toasts and result counts that are silent to screen readers.",
      "Moving focus just to announce a status."
    ]
  },
