# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Node
node_modules/
npm-debug.log*
pnpm-debug.log*
yarn-error.log*

# Motif runtime working area, quarantine is never committed
.motif/quarantine/*
!.motif/quarantine/.gitkeep
.motif/reviewed/*
!.motif/reviewed/.gitkeep
.motif/snapshots/

# Secrets / local config, never track
*.pem
*.key
.env
.env.*
!.env.example
secrets.*
*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Harness / HUD state (not part of project)
.omc/
.claude/

# v3 Motif Live runtime state (generated; never committed)
**/.motif/runs/
**/.motif/twin/
**/.motif/findings/
**/.motif/concepts/
**/.motif/previews/
**/.motif/decisions/
**/.motif/evidence/
**/.motif/baselines/
**/.motif/policies/
**/.motif/rollback/
**/.motif/design-system/
**/.motif/memory/
**/.motif/studio/
**/.motif/atlas/
**/.motif/project/
evals/fixtures/**/.motif/
