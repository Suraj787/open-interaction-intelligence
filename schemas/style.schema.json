{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://interface-intelligence-os.dev/schemas/style.schema.json",
  "title": "style",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "ai_cliche_risk",
    "overuse_risk"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "emotional_impression": {
      "type": "string"
    },
    "visual_principles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "industry_suitability": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "page_suitability": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "density_compatibility": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accessibility_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "performance_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "typography_compatibility": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "layout_compatibility": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trend_maturity": {
      "type": "string",
      "enum": [
        "emerging",
        "current",
        "mature",
        "declining"
      ]
    },
    "overuse_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "ai_cliche_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "implementation_complexity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "appropriate_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inappropriate_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    }
  },
  "additionalProperties": false
}
