{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://interface-intelligence-os.dev/schemas/graph-edge.schema.json",
  "title": "graph-edge",
  "type": "object",
  "required": [
    "from",
    "to",
    "relation"
  ],
  "properties": {
    "from": {
      "type": "string"
    },
    "to": {
      "type": "string"
    },
    "relation": {
      "type": "string",
      "enum": [
        "performs",
        "belongs-to",
        "uses",
        "shows",
        "has-state",
        "solves",
        "implements",
        "requires",
        "validated-by",
        "evidenced-by",
        "conflicts-with",
        "depends-on",
        "navigates-to",
        "produces",
        "governed-by"
      ]
    }
  },
  "additionalProperties": false
}
