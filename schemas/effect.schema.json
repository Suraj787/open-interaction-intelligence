{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://motif.dev/schemas/effect.schema.json",
  "title": "Motif Effect",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "category", "objective", "complexity", "performance_cost", "reduced_motion_fallback"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "objective": { "type": "string" },
    "contexts": { "type": "array", "items": { "type": "string" } },
    "technologies": { "type": "array", "items": { "type": "string" } },
    "frameworks": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "complexity": { "type": "string", "enum": ["low", "medium", "high"] },
    "performance_cost": { "type": "string", "enum": ["low", "medium", "high"] },
    "accessibility_risk": { "type": "string", "enum": ["low", "medium", "high"] },
    "mobile_suitability": { "type": "string", "enum": ["good", "conditional", "poor"] },
    "reduced_motion_fallback": { "type": "string" },
    "enterprise_suitability": { "type": "string", "enum": ["recommended", "conditional", "discouraged"] },
    "marketing_suitability": { "type": "string", "enum": ["recommended", "conditional", "discouraged"] },
    "provenance": { "type": "string", "enum": ["original", "adapted-concept", "browser-native"] },
    "testing": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
