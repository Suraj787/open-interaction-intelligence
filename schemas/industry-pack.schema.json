{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://interface-intelligence-os.dev/schemas/industry-pack.schema.json",
  "title": "industry-pack",
  "type": "object",
  "required": [
    "id",
    "name",
    "users",
    "workflows",
    "risks"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "users": {
      "type": "array"
    },
    "workflows": {
      "type": "array"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "information_objects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "environment_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "domain_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "audit_compliance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accessibility_concerns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "anti_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
