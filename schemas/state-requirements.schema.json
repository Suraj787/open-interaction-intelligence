{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://interface-intelligence-os.dev/schemas/state-requirements.schema.json",
  "title": "state-requirements",
  "type": "object",
  "required": [
    "id",
    "component_type",
    "required_states"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "component_type": {
      "type": "string"
    },
    "required_states": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conditional_states": {
      "type": "array"
    },
    "rationale": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
