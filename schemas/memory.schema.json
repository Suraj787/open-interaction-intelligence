{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://motif.dev/schemas/memory.schema.json",
  "title": "memory",
  "type": "object",
  "required": [
    "id",
    "type",
    "content",
    "date"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "factual",
        "decision",
        "preference",
        "rejected-approach",
        "temporary-assumption"
      ]
    },
    "content": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "author": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "review_date": {
      "type": "string"
    },
    "expiry": {
      "type": "string"
    },
    "invalidation_rule": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "invalidated"
      ]
    }
  },
  "additionalProperties": false
}
