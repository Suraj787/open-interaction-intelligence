{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://interface-intelligence-os.dev/schemas/layout.schema.json",
  "title": "layout",
  "type": "object",
  "required": [
    "id",
    "name",
    "when_to_use"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "when_to_use": {
      "type": "string"
    },
    "when_not_to_use": {
      "type": "string"
    },
    "information_structure": {
      "type": "string"
    },
    "navigation": {
      "type": "string"
    },
    "density": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "responsive_behaviour": {
      "type": "string"
    },
    "accessibility_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compares_with": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
