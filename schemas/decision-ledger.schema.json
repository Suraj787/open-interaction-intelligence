{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://interface-intelligence-os.dev/schemas/decision-ledger.schema.json",
  "title": "decision-ledger",
  "type": "object",
  "required": [
    "id",
    "problem",
    "decision",
    "rationale",
    "date"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "problem": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accessibility_impact": {
      "type": "string"
    },
    "performance_impact": {
      "type": "string"
    },
    "security_impact": {
      "type": "string"
    },
    "implementation": {
      "type": "string"
    },
    "validation": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "review_date": {
      "type": "string"
    },
    "reconsider_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "superseded"
      ]
    },
    "supersedes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
