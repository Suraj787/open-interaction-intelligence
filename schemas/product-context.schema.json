{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://interface-intelligence-os.dev/schemas/product-context.schema.json",
  "title": "product-context",
  "type": "object",
  "required": [
    "version",
    "confidence",
    "product",
    "users"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "product": {
      "type": "object",
      "required": [
        "type",
        "purpose"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "business_model": {
          "type": "string"
        },
        "audience": {
          "type": "string",
          "enum": [
            "internal",
            "public",
            "mixed"
          ]
        },
        "maturity": {
          "type": "string"
        },
        "regulatory_sensitivity": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "expertise": {
            "type": "string"
          },
          "frequency": {
            "type": "string"
          },
          "goals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "information": {
      "type": "object",
      "properties": {
        "density": {
          "type": "string"
        },
        "objects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "properties": {
        "primary_device": {
          "type": "string"
        },
        "secondary_device": {
          "type": "string"
        },
        "connectivity": {
          "type": "string"
        },
        "localisation": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verified": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inferred": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unresolved": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
