{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://motif.dev/schemas/decision.schema.json",
  "title": "Motif Decision Record",
  "description": "Pre-implementation reasoning record produced by the orchestrator skill.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_type", "screen_purpose", "primary_task", "observed_problem",
    "recommended_pattern", "alternatives", "rationale",
    "accessibility_impact", "performance_impact", "dependency_impact",
    "responsive_strategy", "reduced_motion_strategy"
  ],
  "properties": {
    "product_type": { "type": "string" },
    "screen_purpose": { "type": "string" },
    "primary_task": { "type": "string" },
    "observed_problem": { "type": "string" },
    "recommended_pattern": { "type": "string" },
    "effect_technique": { "type": ["string", "null"] },
    "alternatives": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "rationale": { "type": "string" },
    "accessibility_impact": { "type": "string" },
    "performance_impact": { "type": "string" },
    "dependency_impact": { "type": "string" },
    "responsive_strategy": { "type": "string" },
    "reduced_motion_strategy": { "type": "string" }
  }
}
