{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://interface-intelligence-os.dev/schemas/design-genome.schema.json",
  "title": "design-genome",
  "type": "object",
  "required": [
    "version",
    "product"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "product": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "brand_traits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prohibited_traits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "colour_semantics": {
      "type": "object"
    },
    "typography": {
      "type": "object"
    },
    "geometry": {
      "type": "object"
    },
    "spacing": {
      "type": "object"
    },
    "density": {
      "type": "string"
    },
    "elevation": {
      "type": "object"
    },
    "iconography": {
      "type": "string"
    },
    "imagery": {
      "type": "string"
    },
    "content_tone": {
      "type": "string"
    },
    "motion_character": {
      "type": "string"
    },
    "confirmation_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "navigation_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accessibility_posture": {
      "type": "string"
    },
    "performance_posture": {
      "type": "string"
    },
    "framework_conventions": {
      "type": "object"
    },
    "component_conventions": {
      "type": "object"
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
