{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://motif.dev/schemas/design-system-extract.schema.json",
  "title": "design-system-extract",
  "type": "object",
  "required": [
    "extracted_from",
    "generated"
  ],
  "properties": {
    "extracted_from": {
      "type": "string"
    },
    "generated": {
      "type": "string"
    },
    "primitives": {
      "type": "object"
    },
    "semantics": {
      "type": "object"
    },
    "components": {
      "type": "array"
    },
    "motion": {
      "type": "object"
    },
    "density": {
      "type": "object"
    },
    "exceptions": {
      "type": "array"
    },
    "tailwind": {
      "type": "boolean"
    },
    "css_variables": {
      "type": "array"
    }
  }
}
