{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://motif.dev/schemas/finding.schema.json",
  "title": "finding",
  "type": "object",
  "required": [
    "id",
    "type",
    "severity",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "accessibility",
        "performance",
        "security",
        "design-system",
        "originality",
        "state",
        "workflow",
        "responsive",
        "interaction",
        "duplication",
        "licence",
        "dependency",
        "visual-regression"
      ]
    },
    "rule": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "location": {
      "type": "object",
      "properties": {
        "route": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object"
    },
    "impact": {
      "type": "object"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "acknowledged",
        "accepted-risk",
        "planned",
        "fixed",
        "verified",
        "regressed",
        "false-positive"
      ]
    },
    "introduced_commit": {
      "type": "string"
    },
    "suppression": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "expiry": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "detected_by": {
      "type": "string",
      "enum": [
        "static",
        "runtime",
        "model",
        "human"
      ]
    }
  },
  "additionalProperties": false
}
